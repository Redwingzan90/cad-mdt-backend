# ============================================================
# CAD/MDT Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL - Render provides this automatically)
DATABASE_URL="postgresql://user:password@localhost:5432/cad_mdt"

# Authentication
JWT_SECRET="change-me-to-a-random-secret-string"
JWT_EXPIRES_IN="24h"

# CORS (URL of the web UI dev server or production origin)
CORS_ORIGIN="http://localhost:5173"

# FiveM Integration - must match config.lua Config.API.ServerKey
FIVEM_SERVER_KEY="cfxk_1kRjwnUDp7fMl0AGeWZHe_1U24R2"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
